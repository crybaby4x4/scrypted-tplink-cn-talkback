{
  "name": "@crybaby4x4/scrypted-tplink-cn-talkback",
  "version": "0.0.6",
  "description": "Scrypted plugin for TP-Link IPC Chinese version cameras with two-way audio via MULTITRANS protocol",
  "keywords": [
    "scrypted-plugin",
    "scrypted",
    "tplink",
    "camera",
    "ipc",
    "talkback",
    "two-way-audio",
    "multitrans"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "NODE_ENV=production scrypted-webpack",
    "deploy": "scrypted-deploy",
    "watch": "webpack --watch"
  },
  "scrypted": {
    "name": "TP-Link IPC CN Two-Way Audio",
    "type": "MixinProvider",
    "interfaces": [
      "MixinProvider"
    ]
  },
  "dependencies": {
    "@scrypted/sdk": "^0.5.58"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  }
}
