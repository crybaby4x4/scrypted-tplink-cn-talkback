{
  "compilerOptions": {
    "lib": ["es2021"],
    "module": "commonjs",
    "target": "es2021",
    "moduleResolution": "node",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@scrypted/sdk/settings-mixin": ["node_modules/@scrypted/sdk/dist/src/settings-mixin"],
      "@scrypted/sdk/storage-settings": ["node_modules/@scrypted/sdk/dist/src/storage-settings"]
    }
  },
  "include": ["src"]
}
